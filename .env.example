# ── Azure OpenAI ────────────────────────────────────────────────────────────
# From your Azure OpenAI resource → Keys and Endpoint.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.services.ai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here

# The *deployment name* you created in Azure AI Studio (not the base model id).
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# Optional — API version. Defaults to 2024-10-21 if unset.
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Email notifications (Resend API) ────────────────────────────────────────
# Sign up free at https://resend.com → Dashboard → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address — use onboarding@resend.dev for testing (no domain needed)
NOTIFY_FROM=onboarding@resend.dev

# Map each role to a recipient email address
EMAIL_PRODUCTION_MANAGER=manager@example.com
EMAIL_QA_MANAGER=qa-manager@example.com
EMAIL_SUPERVISOR=supervisor@example.com
EMAIL_QA_LOG=qa-log@example.com
